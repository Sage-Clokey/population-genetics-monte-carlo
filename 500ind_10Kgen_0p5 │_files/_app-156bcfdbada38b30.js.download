</i><sub><i>A</i>1<i>A</i>1</sub>",section:o.o.SELECTION,order:0,defaultValue:1,min:0,max:1,step:.001,sliderName:"Fitness Coefficient for <i>A</i>₁<i>A</i>₁",description:"The probability (from 0 to 1) that an individual with the <i>A</i>₁<i>A</i>₁ genotype reproduces relative to individuals with other genotypes."},{name:o.d.SELECTION_WAa,variable:"WAa",variableHTML:"<i>W</i><sub><i>A</i>1<i>A</i>2</sub>",section:o.o.SELECTION,order:1,defaultValue:1,min:0,max:1,step:.001,sliderName:"Fitness Coefficient for <i>A</i>₁<i>A</i>₂",description:"The probability (from 0 to 1) that an individual with the <i>A</i>₁<i>A₂</i> genotype reproduces relative to individuals with other genotypes."},{name:o.d.SELECTION_Waa,variable:"Waa",variableHTML:"<i>W</i><sub><i>A</i>2<i>A</i>2</sub>",section:o.o.SELECTION,order:2,defaultValue:1,min:0,max:1,step:.001,sliderName:"Fitness Coefficient for <i>A</i>₂<i>A</i>₂",description:"The probability (from 0 to 1) that an individual with the <i>A</i>₂<i>A</i>₂ genotype reproduces relative to individuals with other genotypes."},{name:o.d.SELECTION_COEFFICIENT,sliderName:"Selection Coefficient (s)",description:null,variable:"s",variableHTML:"<i>s</i>",section:o.o.SELECTION,order:3,min:1,max:10,step:1,defaultValue:0},{name:o.d.SELECTION_DOMINANCE_COEFFICIENT,sliderName:"Selection Coefficient (s)",description:null,variable:"h",variableHTML:"<i>h</i>",section:o.o.SELECTION,order:4,min:1,max:10,step:1,defaultValue:0},{name:o.d.MUTATION_FORWARD_MUTATION,variable:"mu",variableHTML:"<i>μ</i>",section:o.o.MUTATION,order:0,sliderName:"Forward Mutation Rate",defaultValue:0,min:0,max:10,step:.001,description:"The probability that allele <i>A</i>₁ changes into <i>A</i>₂ per generation. Enter this probability as a number multiplied by a negative exponent with a base of 10. For example, 1 &times; 10⁻\xb2 = 0.01 mutations per generation."},{name:o.d.MUTATION_BACKWARD_MUTATION,variable:"nu",variableHTML:"<i>v</i>",section:o.o.MUTATION,order:1,sliderName:"Reverse Mu