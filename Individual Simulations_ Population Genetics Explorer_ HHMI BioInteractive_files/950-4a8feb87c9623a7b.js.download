o>\n						<mo>(</mo>\n						<msub>\n							<mi>W</mi>\n							<msub>\n								<mn>A</mn>\n								<mn>1</mn>\n							</msub>\n							<msub>\n								<mn>A</mn>\n								<mn>2</mn>\n							</msub>\n						</msub>\n						<mo>/</mo>\n						<msub>\n							<mi>W</mi>\n							<msub>\n								<mn>A</mn>\n								<mn>1</mn>\n							</msub>\n							<msub>\n								<mn>A</mn>\n								<mn>1</mn>\n							</msub>\n						</msub>\n						<mo>)</mo>\n					</mrow>\n				</math>';case"mutation-rate":return'\n				<math xmlns="http://www.w3.org/1998/Math/MathML"><msub><mi>p</mi><mn>1</mn></msub><mo>=</mo><msub><mi>p</mi><mn>0</mn></msub><mo>(</mo><mn>1</mn><mo>-</mo><mi>&#x3BC;</mi><mo>)</mo><mo>+</mo><mi>v</mi><mo>(</mo><mn>1</mn><mo>-</mo><msub><mi>p</mi><mn>0</mn></msub><mo>)</mo></math>\n					';case"migration-rate":return'\n				<math xmlns="http://www.w3.org/1998/Math/MathML"><msub><mi>p</mi><mn>1</mn></msub><mo>=</mo><mo>(</mo><mn>1</mn><mo>-</mo><mi>m</mi><mo>)</mo><msub><mi>p</mi><mn>0</mn></msub><mo>+</mo><mi>m</mi><mo>(</mo><msub><mi>p</mi><mi>M</mi></msub><mo>)</mo></math>';case"inbreeding-1":return'<math xmlns="http://www.w3.org/1998/Math/MathML"><mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>1</mn></msub><msub><mi>A</mi><mn>1</mn></msub><mo>)</mo><mo>=</mo><msup><mi>p</mi><mn>2</mn></msup><mo>(</mo><mn>1</mn><mo>-</mo><mi>F</mi><mo>)</mo><mo>+</mo><mi>F</mi><mi>p</mi></math>';case"inbreeding-2":return'<math xmlns="http://www.w3.org/1998/Math/MathML"><mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>1</mn></msub><msub><mi>A</mi><mn>2</mn></msub><mo>)</mo><mo>=</mo><mn>2</mn><mi>p</mi><mi>q</mi><mo>(</mo><mn>1</mn><mo>-</mo><mi>F</mi><mo>)</mo></math>';case"inbreeding-3":return'<math xmlns="http://www.w3.org/1998/Math/MathML"><mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>2</mn></msub><msub><mi>A</mi><mn>2</mn></msub><mo>)</mo><mo>=</mo><msup><mi>q</mi><mn>2</mn></msup><mo>(</mo><mn>1</mn><mo>-</mo><mi>F</mi><mo>)</mo><mo>+</mo><mi>F</mi><mi>q</mi></math>';case"inbreeding-all":return'<math xmlns="http://www.w3.org/1998/Math/MathML">\n			\n			<mtable>\n			<mtr>\n			<mtd style="text-align:right;">\n			<mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>1</mn></msub><msub><mi>A</mi><mn>1</mn></msub><mo>)</mo>\n			</mtd>\n			<mtd>\n			<mo>=</mo>\n			</mtd>\n			<mtd style="text-align:left;">\n			<msup><mi>p</mi><mn>2</mn></msup><mo>(</mo><mn>1</mn><mo>-</mo><mi>F</mi><mo>)</mo><mo>+</mo><mi>F</mi><mi>p</mi>\n			</mtd>\n			</mtr>\n			<mtr>\n			<mtd style="text-align:right;">\n			<mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>1</mn></msub><msub><mi>A</mi><mn>2</mn></msub><mo>)</mo>\n			</mtd>\n			<mtd>\n			<mo>=</mo>\n			</mtd>\n			<mtd style="text-align:left;">\n			<mn>2</mn><mi>p</mi><mi>q</mi><mo>(</mo><mn>1</mn><mo>-</mo><mi>F</mi><mo>)</mo>\n			</mtd>\n			</mtr>\n			<mtr>\n			<mtd style="text-align:right;">\n			<mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>2</mn></msub><msub><mi>A</mi><mn>2</mn></msub><mo>)</mo>\n			</mtd>\n			<mtd>\n			<mo>=</mo>\n			</mtd>\n			<mtd style="text-align:left;">\n			<msup><mi>q</mi><mn>2</mn></msup><mo>(</mo><mn>1</mn><mo>-</mo><mi>F</mi><mo>)</mo><mo>+</mo><mi>F</mi><mi>q</mi>\n			</mtd>\n			</mtr>\n			</mtable>\n			</math>';case"assort-1":return'<math xmlns="http://www.w3.org/1998/Math/MathML"><mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>1</mn></msub><msub><mi>A</mi><mn>1</mn></msub><mo>)</mo><mo>=</mo><mfrac><mrow><mo>[</mo><mo>(</mo><mn>1</mn><mo>-</mo><mi>&#x3B1;</mi><mo>)</mo><msup><mi>p</mi><mn>2</mn></msup><mo>+</mo><mi>&#x3B1;</mi><mo>(</mo><msup><mi>p</mi><mn>2</mn></msup><mo>+</mo><mstyle displaystyle="true"><mfrac><mrow><mi>p</mi><mi>q</mi></mrow><mn>2</mn></mfrac></mstyle><mo>)</mo><mo>]</mo></mrow><mi>D</mi></mfrac></math>';case"assort-2":return'<math xmlns="http://www.w3.org/1998/Math/MathML"><mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>1</mn></msub><msub><mi>A</mi><mn>2</mn></msub><mo>)</mo><mo>=</mo><mfrac><mrow><mo>[</mo><mo>(</mo><mn>1</mn><mo>-</mo><mi>&#x3B1;</mi><mo>)</mo><mo>(</mo><mn>2</mn><mi>p</mi><mi>q</mi><mo>)</mo><mo>+</mo><mi>&#x3B1;</mi><mo>(</mo><mi>p</mi><mi>q</mi><mo>)</mo><mo>]</mo></mrow><mi>D</mi></mfrac></math>';case"assort-3":return'<math xmlns="http://www.w3.org/1998/Math/MathML"><mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>2</mn></msub><msub><mi>A</mi><mn>2</mn></msub><mo>)</mo><mo>=</mo><mfrac><mrow><mo>[</mo><mo>(</mo><mn>1</mn><mo>-</mo><mi>&#x3B1;</mi><mo>)</mo><msup><mi>q</mi><mn>2</mn></msup><mo>+</mo><mi>&#x3B1;</mi><mo>(</mo><msup><mi>q</mi><mn>2</mn></msup><mo>+</mo><mstyle displaystyle="true"><mfrac><mrow><mi>p</mi><mi>q</mi></mrow><mn>2</mn></mfrac></mstyle><mo>)</mo><mo>]</mo></mrow><mi>D</mi></mfrac></math>';case"assort-all":return'<math xmlns="http://www.w3.org/1998/Math/MathML">\n			<mtable>\n			<mtr>\n			<mtd style="text-align:right;">\n			<mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>1</mn></msub><msub><mi>A</mi><mn>1</mn></msub><mo>)</mo>\n			</mtd>\n			<mtd>\n			<mo>=</mo>\n			</mtd>\n			<mtd style="text-align:left;">\n			<mfrac><mrow><mo>[</mo><mo>(</mo><mn>1</mn><mo>-</mo><mi>&#x3B1;</mi><mo>)</mo><msup><mi>p</mi><mn>2</mn></msup><mo>+</mo><mi>&#x3B1;</mi><mo>(</mo><msup><mi>p</mi><mn>2</mn></msup><mo>+</mo><mstyle displaystyle="true"><mfrac><mrow><mi>p</mi><mi>q</mi></mrow><mn>2</mn></mfrac></mstyle><mo>)</mo><mo>]</mo></mrow><mi>D</mi></mfrac>\n			</mtd>\n			</mtr>\n			<mtr>\n			<mtd style="text-align:right;">\n			<mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>1</mn></msub><msub><mi>A</mi><mn>2</mn></msub><mo>)</mo>\n			</mtd>\n			<mtd>\n			<mo>=</mo>\n			</mtd>\n			<mtd style="text-align:left;">\n			<mfrac><mrow><mo>[</mo><mo>(</mo><mn>1</mn><mo>-</mo><mi>&#x3B1;</mi><mo>)</mo><mo>(</mo><mn>2</mn><mi>p</mi><mi>q</mi><mo>)</mo><mo>+</mo><mi>&#x3B1;</mi><mo>(</mo><mi>p</mi><mi>q</mi><mo>)</mo><mo>]</mo></mrow><mi>D</mi></mfrac>\n			</mtd>\n			</mtr>\n			<mtr>\n			<mtd style="text-align:right;">\n			<mi>P</mi><mo>(</mo><msub><mi>A</mi><mn>2</mn></msub><msub><mi>A</mi><mn>2</mn></msub><mo>)</mo>\n			</mtd>\n			<mtd>\n			<mo>=</mo>\n			</mtd>\n			<mtd style="text-align:left;">\n			<mfrac><mrow><mo>[</mo><mo>(</mo><mn>1</mn><mo>-</mo><mi>&#x3B1;</mi><mo>)</mo><msup><mi>q</mi><mn>2</mn></msup><mo>+</mo><mi>&#x3B1;</mi><mo>(</mo><msup><mi>q</mi><mn>2</mn></msup><mo>+</mo><mstyle displaystyle="true"><mfrac><mrow><mi>p</mi><mi>q</mi></mrow><mn>2</mn></mfrac></mstyle><mo>)</mo><mo>]</mo></mrow><mi>D</mi></mfrac>\n			</mtd>\n			</mtr>\n			</math>';case"assort-4":return'<math xmlns="http://www.w3.org/1998/Math/MathML"><mi>D</mi><mo>=</mo><mo>[</mo><mo>(</mo><mn>1</mn><mo>-</mo><mi>&#x3B1;</mi><mo>)</mo><msup><mi>p</mi><mn>2</mn></msup><mo>+</mo><mi>&#x3B1;</mi><mo>(</mo><msup><mi>p</mi><mn>2</mn></msup><mo>+</mo><mfrac><mrow><mi>p</mi><mi>q</mi></mrow><mn>2</mn></mfrac><mo>)</mo><mo>]</mo><mo>+</mo><mo>[</mo><mo>(</mo><mn>1</mn><mo>-</mo><mi>&#x3B1;</mi><mo>)</mo><mo>(</mo><mn>2</mn><mi>p</mi><mi>q</mi><mo>)</mo><mo>+</mo><mi>&#x3B1;</mi><mo>(</mo><mi>p</mi><mi>q</mi><mo>)</mo><mo>]</mo><mo>+</mo><mo>[</mo><mo>(</mo><mn>1</mn><mo>-</mo><mi>&#x3B1;</mi><mo>)</mo><msup><mi>q</mi><mn>2</mn></msup><mo>+</mo><mi>&#x3B1;</mi><mo>(</mo><msup><mi>q</mi><mn>2</mn></msup><mo>+</mo><mfrac><mrow><mi>p</mi><mi>q</mi></mrow><mn>2</mn></mfrac><mo>)</mo><mo>]</mo></math>';default:return""}}},1306:function(m){m.exports=JSON.parse('[{"question":"Summary","answer":[{"type":"text","value":"In this tool, you’ll explore the frequency of alleles and genotypes in a population using a simulator based on a mathematical model. Use the simulator to explore your own questions about how allele and genotype frequencies are affected by natural selection, migration, mutation, and more. "},{"type":"text","value":"Additional information can be found on <a class=\\"modal-link\\" href=\\"https://www.biointeractive.org/classroom-resources/population-genetics-explorer\\" target=\\"_blank\\" rel=\\"noreferrer\\">this resource’s webpage</a>."}]},{"question":"Instructions for use","answer":[{"type":"text","value":"This resource contains the following sections in the top menu:"},{"type":"list","value":["The <strong>“Introduction”</strong> tab provides a brief overview of population genetics and the model. ","The <strong>“Simulations”</strong> tab is where you can access the model simulator. Navigate the simulator by following the instructions in each section. <ul style=\'margin-left: 15px\'> <li> <strong>“Individual Simulations”</strong> generates one simulation for each group of settings you select. You can use this to compare the effects of different settings. </li> <li> <strong>“Replicated Simulations”</strong> generates multiple simulations with the same settings. Use this to explore the effects of random chance.\\n</li> </ul>","The <strong>“Model Background”</strong> tab provides more information about the biological concepts and terms used in the model.","The <strong>“Help”</strong> tab provides more support for using the simulator.\\n"]},{"type":"text","value":"Throughout the resource, you can select bold underlined text and question mark icons <img src=\'images/question-mark.png\' style=\'width: 1em; height: 1em; display: inline\' /> to show additional information."},{"type":"text","value":"For more information on using this resource, refer to the materials on <a class=\\"modal-link\\" href=\\"https://www.biointeractive.org/classroom-resources/population-genetics-explorer\\" target=\\"_blank\\" rel=\\"noreferrer\\">this resource’s webpage</a>."}]},{"question":"Compatibility and accessibility","answer":[{"type":"text","value":"This resource is optimized for use on computers and mobile devices. It is supported by the most recent versions of Google Chrome, Firefox, Microsoft Edge, and Safari web browsers."},{"type":"text","value":"This resource has been designed, optimized, and tested for <a class=\\"modal-link\\" href=\\"https://www.biointeractive.org/commitment-accessibility\\" target=\\"_blank\\" rel=\\"noreferrer\\"> accessibility </a> compliance (<a class=\'modal-link\' href=\'https://www.w3.org/WAI/standards-guidelines/wcag/\' target=\\"_blank\\">WCAG</a> Level 2.1 AA Success Criteria). "},{"type":"text","value":"Submit comments, questions, or feedback about this resource via email to <a href=\'mailto:biointeractive@hhmi.org?subject=Population Genetics Feedback\' target=\'_blank\' class=\'modal-link\'>biointeractive@hhmi.org</a>. "}]},{"question":"References","answer":"Shaffer, John R., and Joshua Rogan. “Online human population genetics simulator: a tool for genetics/genomics education and research.” (poster, American Society of Human Genetics 65th Annual Meeting. Baltimore, MD, October 9, 2015)."}]')}}]);